
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "isFeatured": { "type": "boolean" },
        "unit": { "type": "string", "description": "e.g., Size, Weight, Color" },
        "variants": { "type": "array", "items": { "type": "string" }, "description": "e.g., ['M', 'L', 'XL'] or ['500g', '1kg']" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Additional information for a user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "fcmToken": { "type": "string", "description": "Token for push notifications" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "appCharge": { "type": "number" },
        "totalAmount": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "location": { "type": "object", "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "address": { "type": "string" }
        }},
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Customizable content for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "primaryColor": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and customer details"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Global site configuration"
    }
  }
}
